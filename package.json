{
  "name": "ai-cost-dashboard",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n api,worker,web -c blue,magenta,green \"npm:dev:api\" \"npm:dev:worker\" \"npm:dev:web\"",
    "dev:api": "tsx watch src/api/index.ts",
    "dev:worker": "tsx watch src/jobs/worker.ts",
    "dev:web": "cd web && vite",
    "build": "tsc && cd web && vite build",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "test": "vitest"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "better-sqlite3": "^11.10.0",
    "bullmq": "^5.7.0",
    "dotenv": "^16.4.1",
    "drizzle-orm": "^0.36.4",
    "fastify": "^4.28.1",
    "ioredis": "^5.3.2",
    "node-cron": "^3.0.3",
    "pino": "^9.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/node": "^20.11.5",
    "@vitest/ui": "^1.2.1",
    "concurrently": "^8.2.2",
    "drizzle-kit": "^0.28.1",
    "prettier": "^3.2.4",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.1"
  }
}
